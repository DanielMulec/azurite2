{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/azurite_title_prefix.py\"",
            "timeout": 10,
            "statusMessage": "Updating Azurite task title"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/azurite_title_prefix.py\"",
            "timeout": 10,
            "statusMessage": "Updating Azurite task title"
          }
        ]
      }
    ]
  }
}
